# Next.js loads this in development only.
# Dev server port is fixed in package.json (`--port 3100`). If you use another port, run
# `npm run dev -- --port 9781` and create `.env.development.local` with the same URL:
#   NEXT_PUBLIC_APP_URL=http://localhost:9781
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
