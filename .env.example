# Copy to `.env.local` for real values (never commit `.env.local`).
# Next.js does not read this file at runtime — it is documentation only.

# Used for absolute URLs and JSON-LD (e.g. https://your-domain.com)
NEXT_PUBLIC_APP_URL=

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=

# Public marketing images: create bucket `site-media` (or set MEDIA_BUCKET) as **public**,
# then upload paths from `src/lib/constants/editorial-media.ts` and `editor-pick-media.ts`.
# While `false`/unset, the app uses curated Unsplash fallbacks in code. If `true`, **only** bucket
# URLs are used — old uploads (e.g. wrong models) will still show until you replace those files.
NEXT_PUBLIC_MEDIA_BUCKET=site-media
# NEXT_PUBLIC_MEDIA_CDN_BASE=https://your-cdn.example.com/kabuki-media
# After uploading to `site-media`, set `true`. Omit or `false` = fallbacks from `editorial-media.ts`.
NEXT_PUBLIC_MARKETING_MEDIA_USE_STORAGE=

# Optional hero background: public MP4 (muted loop). Or upload `editorial/hero-loop.mp4` with storage flag on.
# NEXT_PUBLIC_HERO_VIDEO_URL=https://your-project.supabase.co/storage/v1/object/public/site-media/editorial/hero-loop.mp4

# Paystack (use GHS for Ghana — amount in API is pesewas, ×100)
NEXT_PUBLIC_PAYSTACK_CURRENCY=GHS
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Analytics (optional — enable one or both)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Error monitoring (server)
# SENTRY_DSN=

# Cron (Vercel cron hits /api/cron/reminders with this bearer token)
# CRON_SECRET=

# Marketing / conversion
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=
NEXT_PUBLIC_WHATSAPP_BOOKING_NUMBER=

# PWA / offline (optional). Omit or leave unset: no service worker — site updates show immediately.
# Set to true only if you need install + offline; default Workbox recipe can cache old pages ~24h.
# NEXT_PUBLIC_ENABLE_PWA=true
