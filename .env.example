# Copy to `.env.local` for local development (never commit `.env.local`).

# Production site URL (required for SEO, Open Graph, JSON-LD)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Supabase Storage for salon photography (public bucket)
NEXT_PUBLIC_MEDIA_BUCKET=site-media
# Create a public bucket named site-media in Supabase Storage for admin gallery uploads
# NEXT_PUBLIC_MEDIA_CDN_BASE=
# NEXT_PUBLIC_MARKETING_MEDIA_USE_STORAGE=true

# Paystack — booking deposits (GHS amounts in pesewas, ×100)
NEXT_PUBLIC_PAYSTACK_CURRENCY=GHS
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Webhook URL (Paystack dashboard): https://your-domain.vercel.app/api/paystack/webhook

# Vercel cron — /api/cron/reminders (daily on Hobby plan)
CRON_SECRET=

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=

# Salon contact
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=
NEXT_PUBLIC_WHATSAPP_BOOKING_NUMBER=
# Server-only alerts for new bookings (Resend + Twilio)
SALON_NOTIFY_EMAIL=
SALON_NOTIFY_PHONE=
RESEND_API_KEY=
RESEND_FROM_EMAIL=The Glam Room <hello@theglamroom.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# PWA — leave unset unless you need offline/install (Pro recommended for hourly cron)
# NEXT_PUBLIC_ENABLE_PWA=true
